    };

  fileSystems."/etc/nixos" =
    { device = "/nix/persist/system/etc/nixos";
      fsType = "none";
      options = [ "bind" ];
    };

  fileSystems."/etc/ssh" =
    { device = "/nix/persist/system/etc/ssh";
      fsType = "none";
      options = [ "bind" ];
    };

  fileSystems."/etc/wireguard" =
    { device = "/nix/persist/system/etc/wireguard";
      fsType = "none";
      options = [ "bind" ];
    };

  fileSystems."/var/lib/bluetooth" =
    { device = "/nix/persist/system/var/lib/bluetooth";
      fsType = "none";
      options = [ "bind" ];
    };

  fileSystems."/var/lib/colord" =
    { device = "/nix/persist/system/var/lib/colord";
